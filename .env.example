# ─── IT Policy Manager — Environment Configuration ───────────────────────────
# Copy this file to .env and fill in your values before starting the server.
# NEVER commit .env to version control.

# ── JWT Security ──────────────────────────────────────────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=CHANGE_ME_generate_a_strong_random_secret_here
JWT_ALGORITHM=HS256

# ── Admin Credentials ─────────────────────────────────────────────────────────
# Change these before first run. Password is hashed on first startup.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME_strong_password_here

# ── Ollama LLM ────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:1b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# ── Policy Documents Directory ────────────────────────────────────────────────
# Absolute path to the folder containing your PDF policy documents.
# Defaults to the 'Policies ASH' directory (parent of this project).
# POLICY_DOCS_DIR=/path/to/your/pdf/policies
